# Local middleware settings for Docker Compose.
# Copy this file to .env for local overrides. Do not put production secrets here.

POSTGRES_DB=manga
POSTGRES_USER=manga
POSTGRES_PASSWORD=manga_local_password
POSTGRES_PORT=5432

ELASTICSEARCH_VERSION=8.17.0
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

RABBITMQ_DEFAULT_USER=manga
RABBITMQ_DEFAULT_PASS=manga_local_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Local Spring Boot settings for API / Worker.
DATABASE_URL=jdbc:postgresql://localhost:5432/manga
DATABASE_USERNAME=manga
DATABASE_PASSWORD=manga_local_password
ELASTICSEARCH_URIS=http://localhost:9200
RABBITMQ_HOST=localhost
RABBITMQ_USERNAME=manga
RABBITMQ_PASSWORD=manga_local_password

BOOK_STORAGE_ROOT=./.local/storage
BOOK_STORAGE_ORIGINALS_DIR=books

WORKER_WORK_ROOT=./.local/worker
SEVENZIP_EXECUTABLE_PATH=7z
CONVERSION_WEBP_QUALITY=80
CONVERSION_WORKER_CONCURRENCY=2
CONVERSION_JOB_TIMEOUT=30m
API_FLYWAY_ENABLED=false
WORKER_FLYWAY_ENABLED=false
